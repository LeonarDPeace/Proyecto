{
  "info": {
    "name": "VeraMarket Sprints 1, 2 & 3 API",
    "description": "Colección completa de endpoints para Sprints 1 al 3 del proyecto VeraMarket. Incluye scripts automáticos de inyección de variables entre peticiones.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Servicio activo', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Auth (Sprint 1 - EP-01)",
      "description": "Flujo de autenticación OTP: solicitar código → verificar → completar perfil → solicitar rol vendedor.",
      "item": [
        {
          "name": "1.1 Solicitar OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OTP enviado correctamente', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.email).to.eql(pm.environment.get('test_email'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/otp/request",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "otp", "request"]
            }
          }
        },
        {
          "name": "1.2 Verificar OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token JWT recibido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.access_token).to.be.a('string');",
                  "    pm.environment.set('token', json.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"code\": \"{{otp_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/otp/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "otp", "verify"]
            }
          }
        },
        {
          "name": "1.3 Completar Perfil",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil completado', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string');",
                  "    pm.environment.set('user_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vendedor Demo\",\n  \"institutional_id\": \"2021001234\",\n  \"phone\": \"3001234567\",\n  \"accept_terms\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/profile/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "profile", "complete"]
            }
          }
        },
        {
          "name": "1.4 Actualizar Perfil",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil actualizado', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vendedor Actualizado\",\n  \"phone\": \"3109876543\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "profile"]
            }
          }
        },
        {
          "name": "1.5 Solicitar Rol Vendedor (Sinapsis)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rol de vendedor obtenido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.role).to.eql('vendedor');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sinapsis_code\": \"{{sinapsis_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/vendor/request",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "vendor", "request"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Users & Privacy (Sprint 1 - EP-01)",
      "description": "Gestión de perfil propio, perfil público de terceros y configuración de privacidad.",
      "item": [
        {
          "name": "2.1 Mi Perfil (Privado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil privado obtenido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.email).to.be.a('string');",
                  "    pm.environment.set('user_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me"]
            }
          }
        },
        {
          "name": "2.2 Perfil Público (por ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil público obtenido', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            }
          }
        },
        {
          "name": "2.3 Obtener Config. Privacidad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Config privacidad obtenida', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('show_email');",
                  "    pm.expect(json).to.have.property('show_phone');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me/privacy",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me", "privacy"]
            }
          }
        },
        {
          "name": "2.4 Actualizar Config. Privacidad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Privacidad actualizada', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.show_email).to.eql(true);",
                  "    pm.expect(json.show_phone).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"show_email\": true,\n  \"show_phone\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/me/privacy",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me", "privacy"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Catálogo P2P (Sprint 3 - EP-03)",
      "description": "CRUD completo de productos: crear, listar, obtener, editar, alternar estado y soft-delete.",
      "item": [
        {
          "name": "3.1 Crear Producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Producto creado', function () {",
                  "    pm.response.to.have.status(201);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string');",
                  "    pm.environment.set('product_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Audífonos Bluetooth\",\n  \"description\": \"Poco uso, excelentes bajos. Campus UAO.\",\n  \"price\": 50000,\n  \"category\": \"tecnologia\",\n  \"image_urls\": [\"https://ejemplo.com/audifonos.jpg\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/products/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", ""]
            }
          }
        },
        {
          "name": "3.2 Listar Productos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Lista de productos obtenida', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products/?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", ""],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "3.3 Listar Productos por Categoría",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Filtro por categoría funciona', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products/?category=tecnologia",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", ""],
              "query": [
                { "key": "category", "value": "tecnologia" }
              ]
            }
          }
        },
        {
          "name": "3.4 Obtener Producto por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Producto obtenido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.environment.get('product_id'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "3.5 Editar Producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Producto editado', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.eql('Audífonos Bluetooth Sony');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Audífonos Bluetooth Sony\",\n  \"price\": 45000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "3.6 Alternar Estado (Pausar/Activar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Estado alternado', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('is_active');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}", "status"]
            }
          }
        },
        {
          "name": "3.7 Eliminar Producto (Soft-Delete)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Producto eliminado (soft-delete)', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.include('exitosamente');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Push Notifications (Sprint 2 - EP-02)",
      "description": "Suscripción a notificaciones push vía Service Worker.",
      "item": [
        {
          "name": "4.1 Suscribir Push",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Suscripción guardada', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.message).to.include('guardada');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpoint\": \"https://fcm.googleapis.com/fcm/send/demo-endpoint-12345\",\n  \"keys\": {\n    \"p256dh\": \"demo-p256dh-key\",\n    \"auth\": \"demo-auth-key\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/push/subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "push", "subscribe"]
            }
          }
        }
      ]
    }
  ]
}
