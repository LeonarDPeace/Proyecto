          "name": "5.6 Búsqueda Geo por Radio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Busqueda geoespacial por radio', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    var radius = parseFloat(pm.environment.get('search_radius') || '300');",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    json.items.forEach(function (item) {",
                  "        if (item.distance_meters !== null && item.distance_meters !== undefined) {",
                  "            pm.expect(item.distance_meters).to.be.below(radius + 1);",
                  "        }",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
