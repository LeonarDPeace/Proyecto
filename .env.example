# === Root ===
# Variables de entorno globales de referencia para VeraMarket.
# Copiar a .env y completar con valores reales.

# --- Entorno ---
ENVIRONMENT=development
TZ=America/Bogota

# --- Backend en Docker Compose ---
# Usar host "db" porque el backend corre dentro de la red interna de compose.
DATABASE_URL=postgresql+asyncpg://veramarket:veramarket_dev@db:5432/veramarket
JWT_SECRET=cambiar-por-clave-segura-generada-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:3000

# --- Docker Compose: Sprint 3 Híbrido ---
# API key de Typesense usada por el contenedor y el backend.
TYPESENSE_API_KEY="TU_TYPESENSE_API_KEY"

# API key de Gemini para NLU.
GEMINI_API_KEY="TU_GEMINI_API"
GEMINI_MODEL=gemini-2-flash

# Configuración de Typesense para el backend.
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_TIMEOUT_SECONDS=2.0
TYPESENSE_COLLECTION_PRODUCTS=products

# Límite diario de búsquedas inteligentes.
SEMANTIC_DAILY_LIMIT=10
BUSINESS_TIMEZONE=America/Bogota
