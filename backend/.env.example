# === Backend ===
# Variables de entorno para el backend de VeraMarket (FastAPI).
# Copiar a .env y completar con valores reales. NUNCA commitear .env.

# --- Base de Datos ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/veramarket

# --- Seguridad / JWT ---
JWT_SECRET=cambiar-por-clave-segura-generada-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
ALLOWED_ORIGINS=https://veramarket.app,http://localhost:3000

# --- Entorno ---
ENVIRONMENT=development
TZ=America/Bogota

# --- Email / OTP (Sprint 1 — HU 1.1) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=noreply@veramarket.co
OTP_EXPIRATION_MINUTES=10
OTP_LENGTH=6

# --- Integraciones (Sprint 3) ---
OPENAI_API_KEY=
SENTRY_DSN=

# --- NLU Gemini (Sprint 3 - HU 4.2) ---
# API key obligatoria para interpretar lenguaje natural.
GEMINI_API_KEY="TU_GEMINI_API_KEY"
# Modelo recomendado para costo/latencia.
GEMINI_MODEL=gemini-2-flash

# --- Typesense (Sprint 3 - HU 4.1, HU 5.3) ---
# Debe coincidir con la API key configurada en el contenedor Typesense.
TYPESENSE_API_KEY="XYZ-DEV-TYPESENSE-KEY"
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_TIMEOUT_SECONDS=2.0
TYPESENSE_COLLECTION_PRODUCTS=products

# --- Cuotas de búsqueda inteligente ---
SEMANTIC_DAILY_LIMIT=10
# Zona horaria usada para el reset diario de cuota.
BUSINESS_TIMEZONE=America/Bogota

# --- OAuth (correos institucionales .edu.co) ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# --- Sinapsis (HU 1.4) ---
SINAPSIS_CSV_PATH=data/sinapsis_data.csv
