# === Backend ===
# Variables de entorno para el backend de VeraMarket (FastAPI).
# Copiar a .env y completar con valores reales. NUNCA commitear .env.

# --- Base de Datos ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/veramarket

# --- Seguridad / JWT ---
JWT_SECRET=cambiar-por-clave-segura-generada-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
ALLOWED_ORIGINS=https://veramarket.app,http://localhost:3000

# --- Entorno ---
ENVIRONMENT=development
TZ=America/Bogota

# --- Email / OTP (Sprint 1 — HU 1.1) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=noreply@veramarket.co
OTP_EXPIRATION_MINUTES=10
OTP_LENGTH=6

# --- Integraciones (Sprint 3) ---
OPENAI_API_KEY=
SENTRY_DSN=

# --- OAuth (correos institucionales .edu.co) ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
